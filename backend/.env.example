# Optional: enable the Gemini-backed AI coach. Without this, the coach runs in
# local mode (rules-based, grounded in your real stats). The key is used ONLY
# server-side and is never exposed to the browser.
GEMINI_API_KEY=
# Optional: override the model (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash
